# ── Reddit ─────────────────────────────────────────────────────────────────────
# No credentials needed — workers/reddit.ts uses public JSON endpoints (no auth).
# If you later obtain Reddit API access, add REDDIT_CLIENT_ID etc. here.

# ── Supabase ────────────────────────────────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=REPLACE_WITH_SUPABASE_PROJECT_URL
# WARNING: service role bypasses RLS — never expose client-side
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY
# Safe for browser (used by dashboard)
NEXT_PUBLIC_SUPABASE_URL=REPLACE_WITH_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY

# ── Upstash Redis ───────────────────────────────────────────────────────────────
# console.upstash.com → Create Redis database → REST API tab
UPSTASH_REDIS_REST_URL=REPLACE_WITH_UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_UPSTASH_REDIS_REST_TOKEN

# ── Anthropic ───────────────────────────────────────────────────────────────────
# console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY

# ── Voyage AI (primary embeddings) ─────────────────────────────────────────────
# dash.voyageai.com → API Keys
VOYAGE_API_KEY=REPLACE_WITH_VOYAGE_API_KEY

# ── OpenAI (fallback embeddings only) ──────────────────────────────────────────
# platform.openai.com/api-keys — only needed if Voyage is unavailable
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# ── Vercel Cron ─────────────────────────────────────────────────────────────────
# Generate any random string ≥ 32 chars, e.g.: openssl rand -hex 32
# Add this same value in Vercel Dashboard → Project → Settings → Environment Variables
CRON_SECRET=REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS

# ── Product Hunt ─────────────────────────────────────────────────────────────────
# producthunt.com/v2/oauth/applications → create app → copy Client ID + Secret
PRODUCT_HUNT_CLIENT_ID=REPLACE_WITH_PRODUCT_HUNT_CLIENT_ID
PRODUCT_HUNT_CLIENT_SECRET=REPLACE_WITH_PRODUCT_HUNT_CLIENT_SECRET

# ── Resend (email digest) ────────────────────────────────────────────────────────
# resend.com → API Keys → Create (free tier: 3,000 emails/month)
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
