{%- comment -%}
  The Dog Nook — PDP buy form (variant swatches / select + Add to Cart).
  Split out of sections/dog-nook-product.liquid for reliable deploys.
  Params: product, cur, single_option, add_label
{%- endcomment -%}
{%- liquid
  assign opt_name = product.options.first | downcase
  assign is_size = false
  if opt_name contains 'size'
    assign is_size = true
  endif
-%}
{%- form 'product', product, class: 'tdn-pdp__form' -%}
  {%- if single_option and is_size -%}
    {%- comment -%} Size options → labelled text pills (not colour swatches). {%- endcomment -%}
    <div class="tdn-pdp__optlabel">{{ product.options.first }}: <span data-tdn-swatch-label>{{ cur.title }}</span></div>
    <input type="hidden" name="id" value="{{ cur.id }}">
    <div class="tdn-sizes" data-tdn-swatches role="radiogroup" aria-label="{{ product.options.first | escape }}">
      {%- for variant in product.variants -%}
        <button type="button" class="tdn-sizebtn {% if variant.id == cur.id %}is-selected{% endif %}"
                data-tdn-swatch data-variant-id="{{ variant.id }}" data-variant-name="{{ variant.title | escape }}"
                data-variant-price="{{ variant.price | money }}" data-variant-available="{{ variant.available }}"
                role="radio" aria-checked="{% if variant.id == cur.id %}true{% else %}false{% endif %}"
                {% unless variant.available %}disabled{% endunless %}
                title="{{ variant.title | escape }}">{{ variant.option1 }}</button>
      {%- endfor -%}
    </div>
  {%- elsif single_option -%}
    <div class="tdn-pdp__optlabel">{{ product.options.first }}: <span data-tdn-swatch-label>{{ cur.title }}</span></div>
    <input type="hidden" name="id" value="{{ cur.id }}">
    <div class="tdn-swatches" data-tdn-swatches role="radiogroup" aria-label="{{ product.options.first | escape }}">
      {%- for variant in product.variants -%}
        {%- assign val = variant.option1 | downcase -%}
        {%- liquid
          case val
            when 'sage'
              assign swtone = '#8B9578'
            when 'oat'
              assign swtone = '#DDD3C4'
            when 'clay'
              assign swtone = '#C89178'
            when 'charcoal'
              assign swtone = '#2E2A22'
            when 'cream'
              assign swtone = '#F3EDE4'
            else
              assign swtone = variant.metafields.custom.swatch_hex.value | default: '#9AA593'
          endcase
        -%}
        <button type="button" class="tdn-swatch {% if variant.id == cur.id %}is-selected{% endif %}"
                data-tdn-swatch data-variant-id="{{ variant.id }}" data-variant-name="{{ variant.title | escape }}"
                data-variant-price="{{ variant.price | money }}" data-variant-available="{{ variant.available }}"
                role="radio" aria-checked="{% if variant.id == cur.id %}true{% else %}false{% endif %}"
                {% unless variant.available %}disabled{% endunless %}
                title="{{ variant.title | escape }}" aria-label="{{ variant.title | escape }}"
                style="background: {{ swtone }};"></button>
      {%- endfor -%}
    </div>
  {%- elsif product.has_only_default_variant -%}
    <input type="hidden" name="id" value="{{ cur.id }}">
  {%- else -%}
    <label class="tdn-pdp__optlabel" for="tdn-variant-select">Options</label>
    <select id="tdn-variant-select" name="id" class="tdn-field" style="margin-bottom:24px;">
      {%- for variant in product.variants -%}
        <option value="{{ variant.id }}" {% if variant == cur %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
          {{ variant.title }} — {{ variant.price | money }}{% unless variant.available %} (sold out){% endunless %}
        </option>
      {%- endfor -%}
    </select>
  {%- endif -%}

  {%- if product.available -%}
    <div class="tdn-pdp__stock" style="display:flex; align-items:center; gap:7px; font-size:13.5px; font-weight:600; color:#4d7a3f; margin-bottom:14px;">
      <span style="width:8px; height:8px; border-radius:50%; background:#5aa04a; display:inline-block;"></span>In stock
    </div>
  {%- endif -%}

  <div class="tdn-pdp__qty" style="display:flex; align-items:center; gap:12px; margin-bottom:16px;">
    <label for="tdn-qty" class="tdn-pdp__optlabel" style="margin:0;">Quantity</label>
    <input type="number" id="tdn-qty" name="quantity" value="1" min="1" inputmode="numeric" class="tdn-field" style="width:82px; text-align:center;">
  </div>
  <div class="tdn-pdp__cta">
    {%- if product.available -%}
      {%- comment -%} Primary: green "Buy it now" — adds the item and goes straight to secure checkout. {%- endcomment -%}
      <button type="button" class="tdn-btn tdn-btn--primary tdn-btn--block tdn-pdp__buynow" data-tdn-buynow>
        <span class="tdn-pdp__lock" aria-hidden="true">🔒</span><span>Buy it now — Secure checkout</span>
      </button>
    {%- endif -%}
    {%- comment -%} Secondary: outline Add to Cart (opens the cart drawer). {%- endcomment -%}
    <button type="submit" class="tdn-btn tdn-btn--outline tdn-btn--block tdn-pdp__atc"
            data-tdn-atc data-add-label="{{ add_label | default: 'Add to Cart' }}" data-soldout-label="Sold out"
            {% unless product.available %}disabled{% endunless %}>
      {%- if product.available -%}{{ add_label | default: 'Add to Cart' }}{%- else -%}Sold out{%- endif -%}
    </button>
  </div>

  {%- comment -%} Shop Pay Installments messaging only (no native dynamic-checkout button —
     the custom "Buy it now — Secure checkout" above already does that job, so the
     native {{ form | payment_button }} was removed to avoid a duplicate Buy-it-now). {%- endcomment -%}
  {%- if product.available -%}
    <div class="tdn-pdp__terms">{{ form | payment_terms }}</div>
  {%- endif -%}
{%- endform -%}

<script>
(function () {
  if (window.__tdnBuyNowBound) return;
  window.__tdnBuyNowBound = true;
  document.addEventListener('click', function (e) {
    var btn = e.target.closest ? e.target.closest('[data-tdn-buynow]') : null;
    if (!btn) return;
    var form = btn.closest('form');
    if (!form) return;
    e.preventDefault();
    btn.disabled = true;
    fetch('/cart/add.js', { method: 'POST', body: new FormData(form), headers: { 'Accept': 'application/json' } })
      .then(function (r) { if (!r.ok) throw 0; return r.json(); })
      .then(function () { window.location.href = '/checkout'; })
      .catch(function () { btn.disabled = false; form.submit(); });
  });
})();
</script>
