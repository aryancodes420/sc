{%- comment -%}
  The Dog Nook — free-delivery progress bar for Horizon's cart drawer.
  Computed in Liquid so it updates whenever the drawer re-renders (add/remove).
  Change threshold_cents to match your free-shipping rule (3500 = £35.00).
{%- endcomment -%}
{%- liquid
  assign threshold_cents = 3500
  assign total = cart.total_price
  assign remain = threshold_cents | minus: total
  assign pct = total | times: 100 | divided_by: threshold_cents
  if pct > 100
    assign pct = 100
  endif
-%}
<div class="tdn tdn-cartbar">
  <div class="tdn-cartbar__msg">
    {%- if total >= threshold_cents -%}
      🎉 You’ve unlocked free UK delivery!
    {%- else -%}
      You’re {{ remain | money }} away from free delivery
    {%- endif -%}
  </div>
  <div class="tdn-freeship__bar"><div class="tdn-freeship__fill" style="width: {{ pct }}%;"></div></div>
</div>
<style>
  .tdn-cartbar { padding: 14px var(--cart-drawer-padding, 20px); border-bottom: 1px solid var(--tdn-warm-border); }
  .tdn-cartbar__msg { font-size: 13px; color: var(--tdn-muted-2); margin-bottom: 8px; }
</style>
