{%- comment -%}
  The Dog Nook — star rating.
  Renders a star rating + review count from review-app metafields, with an
  honest empty state when there are no reviews yet. NO invented ratings.

  Compatible with Judge.me / Loox / Shopify Product Reviews, which populate
  `product.metafields.reviews.rating` (rating type) and
  `product.metafields.reviews.rating_count` (integer). When those apps are
  installed and real reviews exist, real stars appear automatically.

  Usage:
    {% render 'dog-nook-stars', stars_product: product, stars_link: true %}
  Params:
    stars_product {Product} required
    stars_link    {Boolean} optional — empty state links to #tdn-reviews (default false)
    stars_align   {String}  optional — 'left' (default) etc. (reserved)
{%- endcomment -%}
{%- liquid
  assign rp = stars_product
  assign rating = 0
  assign count = 0
  assign rmf = rp.metafields.reviews.rating.value
  if rmf != blank
    assign rating = rmf.rating | default: rmf
    assign count = rp.metafields.reviews.rating_count.value | default: 0
  endif
  assign count_num = count | plus: 0
-%}
{%- if count_num > 0 and rating > 0 -%}
  {%- liquid
    assign full = rating | floor
    assign frac = rating | minus: full
    assign half = 0
    if frac >= 0.75
      assign full = full | plus: 1
    elsif frac >= 0.25
      assign half = 1
    endif
    assign empty = 5 | minus: full | minus: half
  -%}
  {%- comment -%} Only a link when stars_link is set (PDP). Inside product cards the whole
     card is already an <a>, and a nested <a> is invalid HTML — it makes the browser split
     the card apart. There we render a <span> instead. {%- endcomment -%}
  {%- if stars_link -%}<a href="#tdn-reviews" class="tdn-stars" aria-label="{{ rating }} out of 5 stars, {{ count_num }} reviews">{%- else -%}<span class="tdn-stars" aria-label="{{ rating }} out of 5 stars, {{ count_num }} reviews">{%- endif -%}
    <span class="tdn-stars__row" aria-hidden="true">
      {%- if full > 0 -%}{%- for i in (1..full) -%}<span class="tdn-star tdn-star--full">★</span>{%- endfor -%}{%- endif -%}
      {%- if half == 1 -%}<span class="tdn-star tdn-star--half"><span>★</span>★</span>{%- endif -%}
      {%- if empty > 0 -%}{%- for i in (1..empty) -%}<span class="tdn-star tdn-star--empty">★</span>{%- endfor -%}{%- endif -%}
    </span>
    <span class="tdn-stars__count">{{ rating }} · {{ count_num }} review{% if count_num != 1 %}s{% endif %}</span>
  {%- if stars_link -%}</a>{%- else -%}</span>{%- endif -%}
{%- else -%}
  {%- if stars_link -%}
    <a href="#tdn-reviews" class="tdn-stars tdn-stars--empty" aria-label="No reviews yet — be the first to review">
      <span class="tdn-stars__row" aria-hidden="true"><span class="tdn-star tdn-star--empty">★</span><span class="tdn-star tdn-star--empty">★</span><span class="tdn-star tdn-star--empty">★</span><span class="tdn-star tdn-star--empty">★</span><span class="tdn-star tdn-star--empty">★</span></span>
      <span class="tdn-stars__count">Be the first to review</span>
    </a>
  {%- else -%}
    <span class="tdn-stars tdn-stars--empty" aria-label="No reviews yet">
      <span class="tdn-stars__row" aria-hidden="true"><span class="tdn-star tdn-star--empty">★</span><span class="tdn-star tdn-star--empty">★</span><span class="tdn-star tdn-star--empty">★</span><span class="tdn-star tdn-star--empty">★</span><span class="tdn-star tdn-star--empty">★</span></span>
      <span class="tdn-stars__count">New</span>
    </span>
  {%- endif -%}
{%- endif -%}
