{%- comment -%}
  The Dog Nook — product card
  Usage: {% render 'dog-nook-product-card', card_product: product, show_tag: true %}
  Accepts:
    card_product  {Product}  required
    show_tag      {Boolean}  optional — show category/type pill (default true)
    tag_text      {String}   optional — override the pill text
    tone          {String}   optional — CSS colour for empty media (fallback placeholder)
{%- endcomment -%}
{%- liquid
  assign p = card_product
  if show_tag == nil
    assign show_tag = true
  endif
  assign pill = tag_text
  if pill == blank
    assign pill = p.type
  endif
  if tone == blank
    assign tone = '#8B9578'
  endif
-%}
<a href="{{ p.url }}" class="tdn-product-card" data-price="{{ p.price }}" data-title="{{ p.title | escape }}" data-date="{{ p.published_at | date: '%s' }}">
  <div class="tdn-product-card__media" style="background: {{ tone }};">
    {%- if p.featured_media -%}
      {%- assign card_alt = p.featured_media.alt | default: p.title | escape -%}
      {{ p.featured_media | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 450, 600', alt: card_alt }}
    {%- endif -%}
    {%- if show_tag and pill != blank -%}
      <span class="tdn-product-card__tag">{{ pill }}</span>
    {%- endif -%}
  </div>
  <div class="tdn-product-card__body">
    <span class="tdn-product-card__name">{{ p.title }}</span>
    <span class="tdn-product-card__reviews">{% render 'dog-nook-stars', stars_product: p %}</span>
    <span class="tdn-product-card__price tdn-price">
      {%- if p.compare_at_price > p.price -%}
        <span class="tdn-product-card__sale">{{ p.price | money }}</span>
        <span class="tdn-compare">{{ p.compare_at_price | money }}</span>
        <span class="tdn-product-card__save">Save {{ p.compare_at_price | minus: p.price | money }}</span>
      {%- else -%}
        {{ p.price | money }}
      {%- endif -%}
    </span>
  </div>
</a>
