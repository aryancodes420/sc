{%- comment -%}
  The Dog Nook — Reviews placeholder.
  Brand rule: no fabricated reviews. Shows empty "awaiting verified review" cards
  until real reviews exist. Swap for a real review app section when you have them.
{%- endcomment -%}
{%- assign s = section.settings -%}
<div class="tdn">
  <section class="tdn-section tdn-wrap" style="text-align:center;">
    {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="tdn-h2">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.body != blank -%}<p class="tdn-muted" style="max-width:520px; margin:-6px auto 26px;">{{ s.body }}</p>{%- endif -%}
    <div class="tdn-grid-3" style="text-align:left;">
      {%- for i in (1..3) -%}
        <div class="tdn-review">
          <div class="tdn-review__stars">★★★★★</div>
          <div class="tdn-review__line" style="width:70%;"></div>
          <div class="tdn-review__line" style="width:90%;"></div>
          <div class="tdn-review__line" style="width:55%;"></div>
          <div class="tdn-review__note">{{ s.placeholder_note }}</div>
        </div>
      {%- endfor -%}
    </div>
  </section>
</div>

{% stylesheet %}
  .tdn-review { border: 1px dashed var(--tdn-warm-border-2); border-radius: 16px; padding: 24px; background: var(--tdn-panel); }
  .tdn-review__stars { color: #d8cdb9; font-size: 18px; letter-spacing: 3px; }
  .tdn-review__line { height: 11px; background: #ede3d3; border-radius: 6px; margin: 8px 0; }
  .tdn-review__line:first-of-type { margin-top: 14px; }
  .tdn-review__note { margin-top: 16px; font-size: 12px; color: #b3a892; }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Reviews placeholder",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Kind words" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real reviews, coming soon" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "We only show reviews once they're real. These spaces are ready for verified owner reviews." },
    { "type": "text", "id": "placeholder_note", "label": "Card note", "default": "Awaiting verified review" }
  ],
  "presets": [ { "name": "TDN Reviews placeholder" } ]
}
{% endschema %}
