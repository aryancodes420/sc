{%- comment -%} The Dog Nook — Trust strip (4 cells) {%- endcomment -%}
<div class="tdn">
  <section class="tdn-wrap tdn-trust">
    <div class="tdn-trust__grid">
      {%- for block in section.blocks -%}
        <div class="tdn-trust__cell" {{ block.shopify_attributes }}>
          <div class="tdn-trust__icon">{{ block.settings.icon }}</div>
          <div class="tdn-trust__title">{{ block.settings.title }}</div>
          <div class="tdn-trust__sub">{{ block.settings.subtitle }}</div>
        </div>
      {%- endfor -%}
    </div>
  </section>
</div>

{% stylesheet %}
  .tdn-trust { padding-top: 8px; }
  .tdn-trust__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  .tdn-trust__cell { background: var(--tdn-card); border: 1px solid var(--tdn-card-border); border-radius: 16px; padding: 20px 16px; text-align: center; }
  .tdn-trust__icon { font-size: 22px; }
  .tdn-trust__title { font-weight: 600; font-size: 14px; margin-top: 6px; }
  .tdn-trust__sub { font-size: 12.5px; color: #7a7264; margin-top: 2px; }
  @media (max-width: 760px) { .tdn-trust__grid { grid-template-columns: repeat(2, 1fr); } }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Trust strip",
  "tag": "section",
  "max_blocks": 4,
  "blocks": [
    { "type": "cell", "name": "Trust cell", "settings": [
      { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🚚" },
      { "type": "text", "id": "title", "label": "Title", "default": "Free UK delivery" },
      { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "On orders over £35" }
    ] }
  ],
  "presets": [ { "name": "TDN Trust strip", "blocks": [
    { "type": "cell", "settings": { "icon": "🚚", "title": "Free UK delivery", "subtitle": "On orders over £35" } },
    { "type": "cell", "settings": { "icon": "🛡️", "title": "30-day guarantee", "subtitle": "Money-back, no fuss" } },
    { "type": "cell", "settings": { "icon": "🐾", "title": "For anxious & rescue dogs", "subtitle": "Chosen with care" } },
    { "type": "cell", "settings": { "icon": "📦", "title": "Fast UK dispatch", "subtitle": "Usually 1–2 days" } }
  ] } ]
}
{% endschema %}
