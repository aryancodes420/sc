{%- comment -%}
  The Dog Nook — moving category marquee.
  A continuously-scrolling row of pills that loops seamlessly.
  Pauses on hover/touch so pills stay clickable. Sits under the header,
  above the hero. Each pill is a block.
{%- endcomment -%}
<div class="tdn tdn-catbar-wrap" data-tdn-catbar>
  <div class="tdn-catbar-inner">
    <div class="tdn-catbar" data-tdn-catbar-viewport>
      <div class="tdn-catbar__track" data-tdn-catbar-track>
        {%- for block in section.blocks -%}
          {%- liquid
            assign url = block.settings.url
            if url == blank and block.settings.collection != blank
              assign url = collections[block.settings.collection].url
            endif
            assign label = block.settings.label
            if label == blank and block.settings.collection != blank
              assign label = collections[block.settings.collection].title
            endif
          -%}
          <a href="{{ url | default: '#' }}" class="tdn-catbar__pill {% if block.settings.accent %}tdn-catbar__pill--accent{% endif %}" {{ block.shopify_attributes }}>{{ label }}</a>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var REDUCE = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function initCatbar(root) {
    if (root.dataset.tdnCatbarReady) return;
    root.dataset.tdnCatbarReady = '1';
    var viewport = root.querySelector('[data-tdn-catbar-viewport]');
    var track = root.querySelector('[data-tdn-catbar-track]');
    if (!track || !viewport) return;

    var originals = Array.prototype.slice.call(track.children);
    if (!originals.length) return;

    if (REDUCE) { viewport.style.overflowX = 'auto'; return; }

    function stride() {
      var first = track.children[0];
      var nextSet = track.children[originals.length];
      if (!nextSet) return track.scrollWidth;
      return nextSet.getBoundingClientRect().left - first.getBoundingClientRect().left;
    }
    function cloneSet() {
      originals.forEach(function (node) {
        var c = node.cloneNode(true);
        c.setAttribute('aria-hidden', 'true');
        c.setAttribute('tabindex', '-1');
        track.appendChild(c);
      });
    }

    cloneSet();
    var step = stride();
    var guard = 0;
    while (track.scrollWidth < viewport.clientWidth + step && guard < 12) { cloneSet(); guard++; }
    step = stride();

    var pos = 0, last = null, hovered = false, hidden = false, speed = 0.035; // px/ms
    function frame(ts) {
      if (last === null) last = ts;
      var dt = ts - last; last = ts;
      if (!hovered && !hidden) {
        pos -= speed * dt;
        if (-pos >= step) pos += step;
        track.style.transform = 'translateX(' + pos + 'px)';
      }
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);

    root.addEventListener('mouseenter', function () { hovered = true; });
    root.addEventListener('mouseleave', function () { hovered = false; last = null; });
    root.addEventListener('touchstart', function () { hovered = true; }, { passive: true });
    root.addEventListener('touchend', function () { setTimeout(function () { hovered = false; last = null; }, 1500); }, { passive: true });
    document.addEventListener('visibilitychange', function () { hidden = document.hidden; if (!hidden) last = null; });
    window.addEventListener('resize', function () { step = stride() || step; });
  }
  function boot() { document.querySelectorAll('[data-tdn-catbar]').forEach(initCatbar); }
  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', boot); } else { boot(); }
  document.addEventListener('shopify:section:load', boot);
})();
</script>

{% schema %}
{
  "name": "TDN Category bar",
  "tag": "section",
  "max_blocks": 12,
  "blocks": [
    { "type": "pill", "name": "Pill", "settings": [
      { "type": "text", "id": "label", "label": "Label (blank = collection title)" },
      { "type": "collection", "id": "collection", "label": "Collection" },
      { "type": "url", "id": "url", "label": "Or a custom link (overrides collection)" },
      { "type": "checkbox", "id": "accent", "label": "Highlight (sage fill)", "default": false }
    ] }
  ],
  "presets": [ { "name": "TDN Category bar", "blocks": [
    { "type": "pill", "settings": { "label": "Shop all", "url": "/pages/shop", "accent": true } },
    { "type": "pill", "settings": { "label": "Calming Essentials", "url": "/collections/calming-essentials" } },
    { "type": "pill", "settings": { "label": "Grooming", "url": "/collections/grooming" } },
    { "type": "pill", "settings": { "label": "Mealtime & Feeding", "url": "/collections/mealtime-feeding" } },
    { "type": "pill", "settings": { "label": "Travel & Outdoor", "url": "/collections/travel-outdoor" } },
    { "type": "pill", "settings": { "label": "The Rescue Bundle", "url": "/products/the-new-rescue-bundle-1" } }
  ] } ]
}
{% endschema %}
