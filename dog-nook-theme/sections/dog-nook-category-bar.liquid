{%- comment -%}
  The Dog Nook — scrolling category carousel.
  A horizontally-scrollable row of pills with prev/next controls.
  Sits directly under the header, above the hero. Each pill is a block.
{%- endcomment -%}
<div class="tdn tdn-catbar-wrap" data-tdn-catbar>
  <div class="tdn-catbar-inner">
    <button type="button" class="tdn-catbar__nav tdn-catbar__nav--prev" aria-label="Scroll categories left" data-tdn-catbar-prev hidden>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <div class="tdn-catbar tdn-scroll" data-tdn-catbar-track>
      {%- for block in section.blocks -%}
        {%- liquid
          assign url = block.settings.url
          if url == blank and block.settings.collection != blank
            assign url = collections[block.settings.collection].url
          endif
          assign label = block.settings.label
          if label == blank and block.settings.collection != blank
            assign label = collections[block.settings.collection].title
          endif
        -%}
        <a href="{{ url | default: '#' }}" class="tdn-catbar__pill {% if block.settings.accent %}tdn-catbar__pill--accent{% endif %}" {{ block.shopify_attributes }}>{{ label }}</a>
      {%- endfor -%}
    </div>
    <button type="button" class="tdn-catbar__nav tdn-catbar__nav--next" aria-label="Scroll categories right" data-tdn-catbar-next hidden>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>
</div>

<script>
(function () {
  function initCatbar(root) {
    if (root.dataset.tdnCatbarReady) return;
    root.dataset.tdnCatbarReady = '1';
    var track = root.querySelector('[data-tdn-catbar-track]');
    var prev = root.querySelector('[data-tdn-catbar-prev]');
    var next = root.querySelector('[data-tdn-catbar-next]');
    if (!track) return;
    function amount() { return Math.max(track.clientWidth * 0.7, 160); }
    function update() {
      var overflow = track.scrollWidth - track.clientWidth > 4;
      var atStart = track.scrollLeft <= 2;
      var atEnd = track.scrollLeft >= (track.scrollWidth - track.clientWidth - 2);
      if (prev) prev.hidden = !overflow || atStart;
      if (next) next.hidden = !overflow || atEnd;
    }
    if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -amount(), behavior: 'smooth' }); });
    if (next) next.addEventListener('click', function () { track.scrollBy({ left: amount(), behavior: 'smooth' }); });
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  }
  function boot() { document.querySelectorAll('[data-tdn-catbar]').forEach(initCatbar); }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
  document.addEventListener('shopify:section:load', boot);
})();
</script>

{% schema %}
{
  "name": "TDN Category bar",
  "tag": "section",
  "max_blocks": 12,
  "blocks": [
    { "type": "pill", "name": "Pill", "settings": [
      { "type": "text", "id": "label", "label": "Label (blank = collection title)" },
      { "type": "collection", "id": "collection", "label": "Collection" },
      { "type": "url", "id": "url", "label": "Or a custom link (overrides collection)" },
      { "type": "checkbox", "id": "accent", "label": "Highlight (sage fill)", "default": false }
    ] }
  ],
  "presets": [ { "name": "TDN Category bar", "blocks": [
    { "type": "pill", "settings": { "label": "Shop all", "url": "/pages/shop", "accent": true } },
    { "type": "pill", "settings": { "label": "Calming Essentials", "url": "/collections/calming-essentials" } },
    { "type": "pill", "settings": { "label": "Grooming", "url": "/collections/grooming" } },
    { "type": "pill", "settings": { "label": "Mealtime & Feeding", "url": "/collections/mealtime-feeding" } },
    { "type": "pill", "settings": { "label": "Travel & Outdoor", "url": "/collections/travel-outdoor" } },
    { "type": "pill", "settings": { "label": "The Rescue Bundle", "url": "/products/the-new-rescue-bundle-1" } }
  ] } ]
}
{% endschema %}
