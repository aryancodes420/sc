{%- comment -%}
  The Dog Nook — Narrow rich-text page (About / story).
  Eyebrow + heading + optional image + body paragraphs (blocks) + optional button.
{%- endcomment -%}
{%- assign s = section.settings -%}
<div class="tdn tdn-fade">
  <section class="tdn-rt">
    {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
    {%- if s.heading != blank -%}<h1 class="tdn-h1" style="font-size:34px; margin-bottom:20px;">{{ s.heading }}</h1>{%- endif -%}
    {%- if s.image != blank or s.image_placeholder_label != blank -%}
      <div class="tdn-rt__img" style="background: {{ s.image_tone | default: 'var(--tdn-grad-calm)' }};">
        {%- if s.image != blank -%}
          {{ s.image | image_url: width: 1200 | image_tag: class: 'tdn-rt__imgtag', widths: '600, 900, 1200', alt: s.heading | escape }}
        {%- else -%}
          <span class="tdn-rt__ph">{{ s.image_placeholder_label }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'paragraph' -%}
        <div class="tdn-rt__body rte" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
      {%- elsif block.type == 'button' -%}
        <a href="{{ block.settings.url | default: '/collections/all' }}" class="tdn-btn tdn-btn--primary tdn-rt__btn" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
      {%- endif -%}
    {%- endfor -%}
  </section>
</div>

{% stylesheet %}
  .tdn-rt { max-width: 720px; margin: 0 auto; padding: 64px var(--tdn-side-pad); }
  .tdn-rt__img { border-radius: 18px; height: 320px; margin-bottom: 26px; display: flex; align-items: flex-end; padding: 16px; overflow: hidden; position: relative; }
  .tdn-rt__imgtag { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tdn-rt__ph { font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,.7); font-weight: 600; position: relative; }
  .tdn-rt__body { font-size: 16px; line-height: 1.75; color: #4a453b; margin: 0 0 18px; }
  .tdn-rt__btn { margin-top: 8px; }
  @media (max-width: 760px) { .tdn-rt { padding: 44px var(--tdn-side-pad); } }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Rich text",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Calm, considered comfort — with a soft spot for rescues" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_tone", "label": "Placeholder colour / gradient (CSS)", "default": "linear-gradient(140deg,#8a9472,#6f795c)" },
    { "type": "text", "id": "image_placeholder_label", "label": "Placeholder label", "default": "Founder + dog photo (optional)" }
  ],
  "blocks": [
    { "type": "paragraph", "name": "Paragraph", "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Write your story here.</p>" } ] },
    { "type": "button", "name": "Button", "settings": [ { "type": "text", "id": "label", "label": "Label", "default": "Shop the range" }, { "type": "url", "id": "url", "label": "Link" } ] }
  ],
  "presets": [ { "name": "TDN Rich text", "blocks": [
    { "type": "paragraph", "settings": { "text": "<p>The Dog Nook started with one anxious rescue and a house full of things that didn't help. We spent months working out what actually settled her — the deep bed she could burrow into, the lick mat that got her through fireworks, the snuffle mat that tired her out on rainy days.</p>" } },
    { "type": "paragraph", "settings": { "text": "<p>So we built a small shop around exactly that: a tight, considered range of comfort and enrichment for dogs who need a little extra reassurance. No random catalogue, no health claims we can't stand behind, no discount-code noise. Just calm, honest kit that earns its place.</p>" } },
    { "type": "paragraph", "settings": { "text": "<p>We're a small UK business run by one person, so a real person answers your emails — usually the same day. If something doesn't help your dog settle, our 30-day guarantee means the risk is ours, not yours.</p>" } },
    { "type": "button", "settings": { "label": "Shop the range", "url": "/collections/all" } }
  ] } ]
}
{% endschema %}
