{%- comment -%}
  The Dog Nook — Collection grid ("Shop by need").
  Each block links a real Shopify collection; falls back to a colour tile when the
  collection has no image.
{%- endcomment -%}
{%- assign s = section.settings -%}
<div class="tdn">
  <section class="tdn-section tdn-wrap" style="text-align:center;">
    {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="tdn-h2">{{ s.heading }}</h2>{%- endif -%}
    <div class="tdn-grid-4" style="text-align:left;">
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        <a href="{{ coll.url | default: '#' }}" class="tdn-coll-card" {{ block.shopify_attributes }}>
          <div class="tdn-coll-card__media" style="background: {{ block.settings.tone | default: '#8B9578' }};">
            {%- if coll.featured_image != blank -%}
              {{ coll.featured_image | image_url: width: 600 | image_tag: class: 'tdn-coll-card__img', loading: 'lazy', alt: coll.title | escape }}
            {%- endif -%}
            <span class="tdn-coll-card__tag">{{ block.settings.title | default: coll.title }}</span>
          </div>
          <div class="tdn-coll-card__foot">
            <span class="tdn-coll-card__name">{{ block.settings.title | default: coll.title }}</span>
            <span class="tdn-coll-card__cta">Shop now →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </section>
</div>

{% stylesheet %}
  .tdn-coll-card { display: block; cursor: pointer; text-decoration: none; color: inherit; }
  .tdn-coll-card__media { position: relative; height: 150px; border-radius: 14px; overflow: hidden; display: flex; align-items: flex-end; padding: 14px; }
  .tdn-coll-card__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tdn-coll-card__tag { position: relative; font-size: 11px; letter-spacing: 1.2px; text-transform: uppercase; color: rgba(255,255,255,.85); font-weight: 600; }
  .tdn-coll-card__foot { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; }
  .tdn-coll-card__name { font-weight: 600; font-size: 15px; }
  .tdn-coll-card__cta { color: var(--tdn-sage); font-weight: 600; font-size: 14px; }
  .tdn-coll-card:hover .tdn-coll-card__cta { color: var(--tdn-sage-hover); }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Collection grid",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by need" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find what your dog needs" }
  ],
  "blocks": [
    { "type": "collection", "name": "Collection", "settings": [
      { "type": "collection", "id": "collection", "label": "Collection" },
      { "type": "text", "id": "title", "label": "Override title (optional)" },
      { "type": "color", "id": "tone", "label": "Placeholder tile colour", "default": "#8B9578" }
    ] }
  ],
  "presets": [ { "name": "TDN Collection grid", "blocks": [
    { "type": "collection", "settings": { "title": "Calming Essentials", "tone": "#8B9578" } },
    { "type": "collection", "settings": { "title": "Grooming", "tone": "#9AA593" } },
    { "type": "collection", "settings": { "title": "Mealtime & Feeding", "tone": "#C89178" } },
    { "type": "collection", "settings": { "title": "Travel & Outdoor", "tone": "#8B9578" } }
  ] } ]
}
{% endschema %}
