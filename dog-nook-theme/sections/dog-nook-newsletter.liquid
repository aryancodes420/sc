{%- comment -%} The Dog Nook — Newsletter band (real Shopify customer form) {%- endcomment -%}
{%- assign s = section.settings -%}
<div class="tdn">
  <section class="tdn-newsletter">
    <div class="tdn-wrap tdn-newsletter__inner">
      {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow tdn-eyebrow--light">{{ s.eyebrow }}</div>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="tdn-h2 tdn-newsletter__heading">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.body != blank -%}<p class="tdn-newsletter__body">{{ s.body }}</p>{%- endif -%}
      {%- form 'customer', class: 'tdn-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p class="tdn-newsletter__ok">{{ s.success_text | default: 'Thanks — you’re on the list!' }}</p>
        {%- else -%}
          <input type="email" name="contact[email]" placeholder="{{ s.placeholder | default: 'Your email address' }}" required class="tdn-newsletter__input">
          <button type="submit" class="tdn-btn tdn-btn--primary">{{ s.button_label | default: 'Join the pack' }}</button>
        {%- endif -%}
      {%- endform -%}
    </div>
  </section>
</div>

{% stylesheet %}
  .tdn-newsletter { background: var(--tdn-charcoal); color: var(--tdn-cream); margin-top: 20px; }
  .tdn-newsletter__inner { padding: 64px var(--tdn-side-pad); text-align: center; max-width: 640px; margin-left: auto; margin-right: auto; }
  .tdn-newsletter__heading { color: var(--tdn-cream); -webkit-text-fill-color: var(--tdn-cream); background: none; margin-bottom: 12px; }
  .tdn-newsletter__body { color: rgba(243,237,228,.75); max-width: 460px; margin: 0 auto 14px; line-height: 1.6; }
  .tdn-newsletter__form { display: flex; gap: 10px; max-width: 440px; margin: 0 auto; align-items: center; justify-content: center; }
  .tdn-newsletter__input { flex: 1 1 auto; min-width: 0; height: 52px; padding: 0 20px; border-radius: 999px; border: 1px solid #4a4437; background: #3a352c; color: var(--tdn-cream); font-size: 14px; font-family: inherit; box-sizing: border-box; }
  .tdn-newsletter__input::placeholder { color: #9a9184; }
  .tdn-newsletter__form .tdn-btn { height: 52px; padding: 0 24px; flex: 0 0 auto; white-space: nowrap; }
  .tdn-newsletter__ok { color: var(--tdn-cream); font-size: 15px; }
  @media (max-width: 620px) {
    .tdn-newsletter__form { flex-direction: column; align-items: stretch; }
    .tdn-newsletter__form .tdn-btn { width: 100%; }
  }
  @media (max-width: 760px) { .tdn-newsletter__inner { padding: 44px var(--tdn-side-pad); } }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the pack" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 10% off your first order" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Join the pack for calm-dog tips and early access to new bundles. No spam." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join the pack" },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "Thanks — you’re on the list!" }
  ],
  "presets": [ { "name": "TDN Newsletter" } ]
}
{% endschema %}
