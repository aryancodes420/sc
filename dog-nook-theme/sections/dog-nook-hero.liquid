{%- comment -%} The Dog Nook — Hero (Variant A: split / Variant B: full-bleed overlay) {%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign btn1_url = s.button_1_url | default: '/collections/all'
  assign btn2_url = s.button_2_url | default: '/collections/all'
-%}
<div class="tdn tdn-fade">
{%- if s.layout == 'fullbleed' -%}
  {%- assign ov1 = s.overlay_color | color_modify: 'alpha', 0.55 -%}
  {%- assign ov2 = s.overlay_color | color_modify: 'alpha', 0.15 -%}
  <section class="tdn-hero-b">
    <div class="tdn-hero-b__grad" style="background: linear-gradient(115deg, {{ s.grad_from }}, {{ s.grad_mid }} 55%, {{ s.grad_to }});"></div>
    <div class="tdn-hero-b__overlay" style="background: linear-gradient(90deg, {{ ov1 }}, {{ ov2 }});"></div>
    <div class="tdn-wrap tdn-hero-b__inner">
      {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow tdn-eyebrow--light">{{ s.eyebrow }}</div>{%- endif -%}
      <h1 class="tdn-h1 tdn-hero__h1">{{ s.heading }}</h1>
      {%- if s.subheading != blank -%}<p class="tdn-hero__sub tdn-hero__sub--light">{{ s.subheading }}</p>{%- endif -%}
      <div class="tdn-hero__btns">
        {%- if s.button_1_label != blank -%}<a href="{{ btn1_url }}" class="tdn-btn tdn-btn--primary">{{ s.button_1_label }}</a>{%- endif -%}
        {%- if s.button_2_label != blank -%}<a href="{{ btn2_url }}" class="tdn-btn tdn-btn--ghost">{{ s.button_2_label }}</a>{%- endif -%}
      </div>
      {%- if s.ticks != blank -%}<div class="tdn-ticks tdn-ticks--light">{% assign ticks = s.ticks | split: '|' %}{% for t in ticks %}<span>✓ {{ t | strip }}</span>{% endfor %}</div>{%- endif -%}
    </div>
  </section>
{%- else -%}
  <section class="tdn-section tdn-hero-a">
    <div class="tdn-wrap tdn-hero-a__grid">
      <div>
        {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
        <h1 class="tdn-h1 tdn-hero__h1">{{ s.heading }}</h1>
        {%- if s.subheading != blank -%}<p class="tdn-hero__sub">{{ s.subheading }}</p>{%- endif -%}
        <div class="tdn-hero__btns">
          {%- if s.button_1_label != blank -%}<a href="{{ btn1_url }}" class="tdn-btn tdn-btn--primary">{{ s.button_1_label }}</a>{%- endif -%}
          {%- if s.button_2_label != blank -%}<a href="{{ btn2_url }}" class="tdn-btn tdn-btn--outline">{{ s.button_2_label }}</a>{%- endif -%}
        </div>
        {%- if s.ticks != blank -%}<div class="tdn-ticks">{% assign ticks = s.ticks | split: '|' %}{% for t in ticks %}<span>✓ {{ t | strip }}</span>{% endfor %}</div>{%- endif -%}
      </div>
      <div class="tdn-hero-a__media" style="background: {{ s.image_tone | default: 'var(--tdn-grad-calm)' }};">
        {%- if s.image != blank -%}
          {{ s.image | image_url: width: 1200 | image_tag: widths: '600, 900, 1200', class: 'tdn-hero-a__img', alt: s.image.alt | default: s.heading | escape }}
        {%- else -%}
          <span class="tdn-hero-a__ph">{{ s.image_placeholder_label }}</span>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}
</div>

{% stylesheet %}
  .tdn-hero__h1 { font-size: 58px; }
  .tdn-hero__sub { font-size: 17px; line-height: 1.6; color: var(--tdn-muted-2); max-width: 440px; margin: 0 0 26px; }
  .tdn-hero__sub--light { color: rgba(255,255,255,.9); }
  .tdn-hero__btns { display: flex; flex-wrap: wrap; gap: 12px; }
  .tdn-ticks { margin-top: 22px; }
  .tdn-ticks--light { color: rgba(255,255,255,.85); }
  .tdn-hero-a__grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: 48px; align-items: center; }
  .tdn-hero-a__media { position: relative; min-height: 420px; border-radius: 20px; overflow: hidden; display: flex; align-items: flex-end; padding: 20px; }
  .tdn-hero-a__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tdn-hero-a__ph { font-size: 15px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,.85); font-weight: 600; }
  .tdn-hero-b { position: relative; overflow: hidden; display: flex; align-items: center; min-height: 520px; }
  .tdn-hero-b__grad { position: absolute; inset: 0; }
  .tdn-hero-b__overlay { position: absolute; inset: 0; background: linear-gradient(90deg, var(--ov1), var(--ov2)); }
  .tdn-hero-b__inner { position: relative; z-index: 2; padding-top: 64px; padding-bottom: 64px; color: #fff; }
  .tdn-hero-b .tdn-hero__h1 { font-size: 64px; font-weight: 700; }
  @media (max-width: 760px) {
    .tdn-hero__h1 { font-size: 40px; }
    .tdn-hero-b .tdn-hero__h1 { font-size: 42px; }
    .tdn-hero-a__grid { grid-template-columns: 1fr; gap: 28px; }
    .tdn-hero-a__media { min-height: 260px; }
    .tdn-hero-b { min-height: 440px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Hero",
  "tag": "section",
  "class": "tdn-section-wrap",
  "settings": [
    { "type": "select", "id": "layout", "label": "Layout", "default": "fullbleed",
      "options": [
        { "value": "split", "label": "A · Split (image right)" },
        { "value": "fullbleed", "label": "B · Full-bleed overlay" }
      ] },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Made for anxious & rescue dogs" },
    { "type": "text", "id": "heading", "label": "Heading (use <br> for a line break)", "default": "Less anxious.<br>More at home." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Calming beds, mats and grooming tools for dogs who need a little extra reassurance." },
    { "type": "text", "id": "ticks", "label": "Tick list (separate with | )", "default": "30-day money-back guarantee | Free UK delivery over £35" },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "button_1_label", "label": "Primary button label", "default": "Shop the Rescue Bundle" },
    { "type": "url", "id": "button_1_url", "label": "Primary button link" },
    { "type": "text", "id": "button_2_label", "label": "Secondary button label", "default": "Shop all" },
    { "type": "url", "id": "button_2_url", "label": "Secondary button link" },
    { "type": "header", "content": "Layout A — image" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "image_tone", "label": "Placeholder colour / gradient (CSS)", "default": "linear-gradient(140deg,#8a9472,#6f795c)" },
    { "type": "text", "id": "image_placeholder_label", "label": "Placeholder label", "default": "Calm dog on bed" },
    { "type": "header", "content": "Layout B — gradient & overlay" },
    { "type": "color", "id": "grad_from", "label": "Gradient start", "default": "#6f795c" },
    { "type": "color", "id": "grad_mid", "label": "Gradient middle", "default": "#8a9472" },
    { "type": "color", "id": "grad_to", "label": "Gradient end", "default": "#b98a67" },
    { "type": "color", "id": "overlay_color", "label": "Overlay colour (darkens left→right)", "default": "#2e2a22" }
  ],
  "presets": [ { "name": "TDN Hero" } ]
}
{% endschema %}
