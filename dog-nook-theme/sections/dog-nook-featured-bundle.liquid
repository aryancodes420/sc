{%- comment -%}
  The Dog Nook — Featured bundle (2-col card).
  Pick a real product for live price / add-to-cart, or leave blank to use manual prices.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign prod = all_products[s.product]
  assign has_prod = false
  if prod != blank and prod.id
    assign has_prod = true
  endif
-%}
<div class="tdn">
  <section class="tdn-wrap tdn-section">
    <div class="tdn-bundle">
      <div class="tdn-bundle__img" style="background: {{ s.image_tone | default: 'var(--tdn-grad-bundle)' }};">
        {%- if s.image != blank -%}{{ s.image | image_url: width: 900 | image_tag: class: 'tdn-bundle__bg', widths: '450, 700, 900', alt: '' }}{%- endif -%}
        {%- if s.badge != blank -%}<span class="tdn-badge tdn-bundle__badge">{{ s.badge }}</span>{%- endif -%}
        {%- if s.image == blank -%}<span class="tdn-bundle__ph">{{ s.image_placeholder_label }}</span>{%- endif -%}
      </div>
      <div class="tdn-bundle__body">
        {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
        <h2 class="tdn-h2" style="font-size:30px; margin-bottom:14px;">{{ s.heading }}</h2>
        <p class="tdn-muted">{{ s.body }}</p>
        <div class="tdn-bundle__prices">
          {%- if has_prod -%}
            <span class="tdn-price" style="font-size:28px;">{{ prod.price | money }}</span>
            {%- if prod.compare_at_price > prod.price -%}
              <span class="tdn-bundle__compare">{{ prod.compare_at_price | money }}</span>
              <span class="tdn-badge">You save {{ prod.compare_at_price | minus: prod.price | money }}</span>
            {%- endif -%}
          {%- else -%}
            <span class="tdn-price" style="font-size:28px;">{{ s.price }}</span>
            {%- if s.compare_price != blank -%}<span class="tdn-bundle__compare">{{ s.compare_price }}</span>{%- endif -%}
            {%- if s.save_label != blank -%}<span class="tdn-badge">{{ s.save_label }}</span>{%- endif -%}
          {%- endif -%}
        </div>
        <div class="tdn-bundle__actions">
          {%- if has_prod and prod.available -%}
            {%- form 'product', prod -%}
              <input type="hidden" name="id" value="{{ prod.selected_or_first_available_variant.id }}">
              <button type="submit" class="tdn-btn tdn-btn--primary">{{ s.button_label }}</button>
            {%- endform -%}
          {%- else -%}
            <a href="{{ s.button_url | default: prod.url | default: '#' }}" class="tdn-btn tdn-btn--primary">{{ s.button_label }}</a>
          {%- endif -%}
          {%- if s.link_label != blank -%}<a href="{{ s.link_url | default: prod.url | default: '#' }}" class="tdn-bundle__link">{{ s.link_label }}</a>{%- endif -%}
        </div>
      </div>
    </div>
  </section>
</div>

{% stylesheet %}
  .tdn-bundle { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--tdn-card-border); border-radius: 22px; overflow: hidden; background: var(--tdn-card); }
  .tdn-bundle__img { position: relative; min-height: 340px; display: flex; align-items: center; justify-content: center; }
  .tdn-bundle__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tdn-bundle__badge { position: absolute; top: 16px; left: 16px; }
  .tdn-bundle__ph { font-size: 14px; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,.85); font-weight: 600; }
  .tdn-bundle__body { padding: 40px; display: flex; flex-direction: column; justify-content: center; }
  .tdn-bundle__prices { display: flex; align-items: baseline; gap: 12px; margin: 18px 0; flex-wrap: wrap; }
  .tdn-bundle__compare { font-size: 16px; color: var(--tdn-faint-2); text-decoration: line-through; }
  .tdn-bundle__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; }
  .tdn-bundle__actions form { margin: 0; }
  .tdn-bundle__link { font-weight: 600; font-size: 14px; text-decoration: underline; cursor: pointer; }
  @media (max-width: 760px) { .tdn-bundle { grid-template-columns: 1fr; } .tdn-bundle__body { padding: 28px; } .tdn-bundle__img { min-height: 240px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Featured bundle",
  "tag": "section",
  "settings": [
    { "type": "product", "id": "product", "label": "Bundle product (for live price + add to cart)", "info": "Optional. If set, price and Add-to-basket use this product." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured bundle" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The New Rescue Bundle" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Lick mat + snuffle mat + slow-feeder bowl — three gentle essentials to help a nervous dog settle, sniff and unwind." },
    { "type": "text", "id": "badge", "label": "Image badge", "default": "BEST VALUE · SAVE £15" },
    { "type": "header", "content": "Manual price (used only when no product is picked)" },
    { "type": "text", "id": "price", "label": "Price", "default": "£34.99" },
    { "type": "text", "id": "compare_price", "label": "Compare-at price", "default": "£49.97" },
    { "type": "text", "id": "save_label", "label": "Save chip", "default": "You save £15" },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Add bundle to basket" },
    { "type": "url", "id": "button_url", "label": "Button link (if no product)" },
    { "type": "text", "id": "link_label", "label": "Text link label", "default": "What's inside?" },
    { "type": "url", "id": "link_url", "label": "Text link URL" },
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_tone", "label": "Placeholder colour / gradient (CSS)", "default": "linear-gradient(140deg,#c79079,#a86b4f)" },
    { "type": "text", "id": "image_placeholder_label", "label": "Placeholder label", "default": "Bundle flat-lay" }
  ],
  "presets": [ { "name": "TDN Featured bundle" } ]
}
{% endschema %}
