{%- comment -%}
  The Dog Nook — Bundle page (dedicated "What's inside" layout).
  Use as the main section of a product template (templates/product.bundle.json)
  assigned to the bundle product. Price + Add to cart are wired to the product.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign cur = product.selected_or_first_available_variant
-%}
<div class="tdn tdn-fade" data-tdn-product>
  <section class="tdn-section tdn-wrap">
    <div class="tdn-pdp">
      <div class="tdn-bundlep__img" style="background: {{ s.image_tone | default: 'linear-gradient(140deg,#c79079,#a86b4f)' }};">
        {%- if product.featured_media -%}
          {%- assign b_alt = product.featured_media.alt | default: product.title | escape -%}
          {{ product.featured_media | image_url: width: 1000 | image_tag: class: 'tdn-bundlep__bg', widths: '500, 750, 1000', alt: b_alt }}
        {%- endif -%}
        {%- if s.badge != blank -%}<span class="tdn-bundlep__badge">{{ s.badge }}</span>{%- endif -%}
        {%- if product.featured_media == blank -%}<span class="tdn-bundlep__ph">{{ s.image_placeholder_label }}</span>{%- endif -%}
      </div>

      <div class="tdn-bundlep__body">
        {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
        <h1 class="tdn-h1 tdn-bundlep__h1">{{ s.heading | default: product.title }}</h1>
        {%- if s.intro != blank -%}<p class="tdn-bundlep__intro">{{ s.intro }}</p>{%- endif -%}

        {%- assign items = section.blocks | where: 'type', 'item' -%}
        {%- if items.size > 0 -%}
          <div class="tdn-bundlep__panel">
            <div class="tdn-bundlep__panel-label">{{ s.panel_label | default: "What's inside" }}</div>
            {%- for block in items -%}
              <div class="tdn-bundlep__row" {{ block.shopify_attributes }}>
                <div class="tdn-bundlep__swatch" style="background: {{ block.settings.tone | default: '#C89178' }};"></div>
                <div class="tdn-bundlep__rowbody">
                  <div class="tdn-bundlep__rowname">{{ block.settings.name }}</div>
                  <div class="tdn-bundlep__rownote">{{ block.settings.note }}</div>
                </div>
                <div class="tdn-bundlep__rowprice">{{ block.settings.price }}</div>
              </div>
            {%- endfor -%}
            {%- if s.separately_total != blank -%}
              <div class="tdn-bundlep__sep"><span>Bought separately</span><span class="tdn-strike">{{ s.separately_total }}</span></div>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="tdn-bundlep__prices">
          <span class="tdn-price tdn-bundlep__price" data-tdn-price>{{ cur.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="tdn-badge">You save {{ product.compare_at_price | minus: product.price | money }}</span>
          {%- elsif s.save_label != blank -%}
            <span class="tdn-badge">{{ s.save_label }}</span>
          {%- endif -%}
        </div>

        {%- form 'product', product -%}
          <input type="hidden" name="id" value="{{ cur.id }}">
          <button type="submit" class="tdn-btn tdn-btn--primary tdn-btn--block tdn-bundlep__atc" data-tdn-atc data-add-label="{{ s.button_label | default: 'Add bundle to basket' }}" {% unless product.available %}disabled{% endunless %}>
            {%- if product.available -%}{{ s.button_label | default: 'Add bundle to basket' }}{%- else -%}Sold out{%- endif -%}
          </button>
        {%- endform -%}

        <div class="tdn-ticks tdn-bundlep__ticks">
          {%- assign ticks = s.ticks | split: '|' -%}
          {%- for t in ticks -%}<span>✓ {{ t | strip }}</span>{%- endfor -%}
        </div>
      </div>
    </div>
  </section>
</div>

{% stylesheet %}
  .tdn-pdp { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  @media (max-width: 760px) { .tdn-pdp { grid-template-columns: 1fr; gap: 24px; } }
  .tdn-bundlep__img { position: relative; border-radius: 20px; min-height: 460px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .tdn-bundlep__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tdn-bundlep__badge { position: absolute; top: 16px; left: 16px; background: var(--tdn-charcoal); color: #fff; font-size: 11px; font-weight: 700; letter-spacing: .4px; padding: 7px 12px; border-radius: 999px; }
  .tdn-bundlep__ph { font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,.85); font-weight: 600; }
  .tdn-bundlep__body { display: flex; flex-direction: column; justify-content: center; }
  .tdn-bundlep__h1 { font-size: 32px; line-height: 1.12; }
  .tdn-bundlep__intro { font-size: 15px; line-height: 1.7; color: var(--tdn-muted-2); margin: 0 0 20px; }
  .tdn-bundlep__panel { background: var(--tdn-panel); border: 1px solid var(--tdn-card-border); border-radius: 16px; padding: 20px; margin-bottom: 20px; }
  .tdn-bundlep__panel-label { font-size: 12px; letter-spacing: .6px; text-transform: uppercase; color: var(--tdn-faint); font-weight: 600; margin-bottom: 14px; }
  .tdn-bundlep__row { display: flex; align-items: center; gap: 14px; padding: 10px 0; border-bottom: 1px solid #eee2d0; }
  .tdn-bundlep__swatch { width: 46px; height: 46px; border-radius: 10px; flex-shrink: 0; }
  .tdn-bundlep__rowbody { flex: 1; }
  .tdn-bundlep__rowname { font-weight: 600; font-size: 14.5px; }
  .tdn-bundlep__rownote { font-size: 12.5px; color: var(--tdn-faint); }
  .tdn-bundlep__rowprice { font-weight: 600; font-size: 14px; color: var(--tdn-muted-2); }
  .tdn-bundlep__sep { display: flex; justify-content: space-between; align-items: center; padding-top: 14px; font-size: 13.5px; color: var(--tdn-faint); }
  .tdn-strike { text-decoration: line-through; }
  .tdn-bundlep__prices { display: flex; align-items: baseline; gap: 12px; margin-bottom: 18px; flex-wrap: wrap; }
  .tdn-bundlep__price { font-size: 32px; }
  .tdn-bundlep__atc { padding: 15px; font-size: 15px; margin-bottom: 14px; }
  .tdn-bundlep__ticks { flex-direction: column; gap: 8px; }
  @media (max-width: 760px) { .tdn-bundlep__img { min-height: 300px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Bundle page",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Rescue Bundle" },
    { "type": "text", "id": "heading", "label": "Heading (blank = product title)", "default": "Three gentle essentials for a nervous dog settling in" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "The first few weeks with a newly-adopted dog are the hardest — everything is unfamiliar and their nerves are close to the surface. This bundle brings together three of our calmest, most-reached-for tools to help them settle, sniff and unwind at their own pace." },
    { "type": "text", "id": "panel_label", "label": "Panel label", "default": "What's inside" },
    { "type": "text", "id": "separately_total", "label": "Bought-separately total", "default": "£49.97" },
    { "type": "text", "id": "save_label", "label": "Save chip (if no compare-at price)", "default": "You save £15" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Add bundle to basket" },
    { "type": "text", "id": "ticks", "label": "Ticks (separate with | )", "default": "30-day money-back guarantee | Dispatched fast · Free UK delivery over £35" },
    { "type": "text", "id": "badge", "label": "Image badge", "default": "BEST VALUE · SAVE £15" },
    { "type": "text", "id": "image_tone", "label": "Placeholder colour / gradient (CSS)", "default": "linear-gradient(140deg,#c79079,#a86b4f)" },
    { "type": "text", "id": "image_placeholder_label", "label": "Placeholder label", "default": "Flat-lay of all three" }
  ],
  "blocks": [
    { "type": "item", "name": "Item", "settings": [
      { "type": "text", "id": "name", "label": "Name", "default": "Lick Mat" },
      { "type": "text", "id": "note", "label": "Note", "default": "Spread, freeze, soothe" },
      { "type": "text", "id": "price", "label": "Price", "default": "£11.99" },
      { "type": "color", "id": "tone", "label": "Swatch colour", "default": "#C89178" }
    ] }
  ],
  "presets": [ { "name": "TDN Bundle page", "blocks": [
    { "type": "item", "settings": { "name": "Lick Mat", "note": "Spread, freeze, soothe", "price": "£11.99", "tone": "#C89178" } },
    { "type": "item", "settings": { "name": "Snuffle Mat", "note": "Nose-led foraging", "price": "£22.99", "tone": "#9AA593" } },
    { "type": "item", "settings": { "name": "Slow-Feeder Bowl", "note": "Calmer mealtimes", "price": "£14.99", "tone": "#8B9578" } }
  ] } ]
}
{% endschema %}
