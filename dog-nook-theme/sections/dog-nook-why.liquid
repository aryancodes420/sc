{%- comment -%} The Dog Nook — Why-us (eyebrow + heading + up to 3 cards) {%- endcomment -%}
{%- assign s = section.settings -%}
<div class="tdn">
  <section class="tdn-section tdn-wrap" style="text-align:center;">
    {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="tdn-h2">{{ s.heading }}</h2>{%- endif -%}
    <div class="tdn-grid-3" style="text-align:left;">
      {%- for block in section.blocks -%}
        <div class="tdn-card" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}<div style="font-size:24px; margin-bottom:12px;">{{ block.settings.icon }}</div>{%- endif -%}
          <h3 class="tdn-h3">{{ block.settings.title }}</h3>
          <p class="tdn-muted" style="margin:0;">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "TDN Why-us",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why The Dog Nook" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Comfort you can return with confidence" }
  ],
  "blocks": [
    { "type": "card", "name": "Card", "settings": [
      { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🐕" },
      { "type": "text", "id": "title", "label": "Title", "default": "Chosen for anxious & rescue dogs" },
      { "type": "textarea", "id": "body", "label": "Body", "default": "Picked for dogs settling in — not a random catalogue. Everything here earns its place." }
    ] }
  ],
  "presets": [ { "name": "TDN Why-us", "blocks": [
    { "type": "card", "settings": { "icon": "🐕", "title": "Chosen for anxious & rescue dogs", "body": "Picked for dogs settling in — not a random catalogue. Everything here earns its place." } },
    { "type": "card", "settings": { "icon": "🛡️", "title": "The risk is ours, not yours", "body": "A 30-day money-back guarantee on every order. If it doesn't help your dog settle, send it back." } },
    { "type": "card", "settings": { "icon": "💬", "title": "A real person replies", "body": "One real person (based in the UK) replies — usually the same day. Ask us anything before you buy." } }
  ] } ]
}
{% endschema %}
