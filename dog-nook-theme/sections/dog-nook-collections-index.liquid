{%- comment -%} The Dog Nook — Collections index. Bundle collections get a save-badge + CTA. {%- endcomment -%}
{%- assign s = section.settings -%}
<div class="tdn tdn-fade">
  <section class="tdn-section tdn-wrap">
    {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
    {%- if s.heading != blank -%}<h1 class="tdn-h1" style="font-size:32px; margin-bottom:26px;">{{ s.heading }}</h1>{%- endif -%}
    <div class="tdn-grid-2">
      {%- if s.collection_list.count > 0 -%}
        {%- assign coll_list = s.collection_list -%}
      {%- else -%}
        {%- assign coll_list = collections -%}
      {%- endif -%}
      {%- for coll in coll_list -%}
        {%- if coll.handle == 'frontpage' or coll.products_count == 0 -%}{%- continue -%}{%- endif -%}
        {%- liquid
          assign has_bundle = false
          assign best_save = 0
          for bp in coll.products
            if bp.type == 'Bundle' or bp.handle contains 'bundle'
              assign has_bundle = true
              if bp.compare_at_price > bp.price
                assign bp_save = bp.compare_at_price | minus: bp.price
                if bp_save > best_save
                  assign best_save = bp_save
                endif
              endif
            endif
          endfor
        -%}
        <a href="{{ coll.url }}" class="tdn-cindex">
          <div class="tdn-cindex__media" style="background: #8B9578;">
            {%- if coll.featured_image != blank -%}
              {{ coll.featured_image | image_url: width: 900 | image_tag: class: 'tdn-cindex__img', loading: 'lazy', alt: coll.title | escape }}
            {%- endif -%}
            {%- if has_bundle -%}
              <span class="tdn-cindex__badge">{% if best_save > 0 %}Bundle inside · Save {{ best_save | money }}{% else %}Money-saving bundle inside{% endif %}</span>
            {%- endif -%}
          </div>
          <div class="tdn-cindex__body">
            <div class="tdn-cindex__name">{{ coll.title }}</div>
            <div class="tdn-cindex__cta">{% if has_bundle %}See the bundle →{% else %}Shop now →{% endif %}</div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </section>
</div>

{% stylesheet %}
  .tdn-cindex { display: block; border-radius: 18px; overflow: hidden; border: 1px solid var(--tdn-card-border); background: #fff; text-decoration: none; color: inherit; transition: transform .18s, box-shadow .18s; }
  .tdn-cindex:hover { transform: translateY(-3px); box-shadow: 0 14px 30px rgba(46,42,34,.10); color: inherit; }
  .tdn-cindex__media { position: relative; height: 190px; overflow: hidden; }
  .tdn-cindex__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tdn-cindex__badge { position: absolute; top: 12px; left: 12px; z-index: 1; background: var(--tdn-terracotta); color: #fff; font-size: 12px; font-weight: 700; letter-spacing: .2px; padding: 6px 12px; border-radius: 999px; box-shadow: 0 2px 8px rgba(46,42,34,.18); }
  .tdn-cindex__body { padding: 20px; }
  .tdn-cindex__name { font-family: var(--tdn-font-display); font-size: 20px; font-weight: 600; margin-bottom: 6px; }
  .tdn-cindex__cta { color: var(--tdn-sage); font-weight: 600; font-size: 14px; }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Collections index",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by need" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collections" },
    { "type": "collection_list", "id": "collection_list", "label": "Collections to show", "info": "Leave empty to show all collections." }
  ],
  "presets": [ { "name": "TDN Collections index" } ]
}
{% endschema %}
