{%- comment -%} The Dog Nook — Contact (real Shopify contact form) {%- endcomment -%}
{%- assign s = section.settings -%}
<div class="tdn tdn-fade">
  <section class="tdn-contact">
    {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
    {%- if s.heading != blank -%}<h1 class="tdn-h1" style="font-size:32px; margin-bottom:12px;">{{ s.heading }}</h1>{%- endif -%}
    <p class="tdn-contact__lead">Email us directly at <a href="mailto:{{ s.email }}">{{ s.email }}</a> or use the form below.</p>
    {%- if s.subtext != blank -%}<p class="tdn-contact__sub">{{ s.subtext }}</p>{%- endif -%}

    {%- form 'contact', class: 'tdn-contact__form' -%}
      {%- if form.posted_successfully? -%}
        <p class="tdn-contact__ok">{{ s.success_text | default: 'Thanks — we’ll reply within 24 hours.' }}</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="tdn-contact__err">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <input type="text" name="contact[name]" placeholder="Your name" aria-label="Your name" class="tdn-field" value="{{ form.name }}" required>
      <input type="email" name="contact[email]" placeholder="Your email" aria-label="Your email" class="tdn-field" value="{{ form.email }}" required>
      <textarea name="contact[body]" placeholder="How can we help?" aria-label="How can we help?" rows="5" class="tdn-field" style="resize:vertical;">{{ form.body }}</textarea>
      <button type="submit" class="tdn-btn tdn-btn--primary" style="align-self:flex-start;">{{ s.button_label | default: 'Send message' }}</button>
    {%- endform -%}

    {%- comment -%} Trader identity — legally required, kept deliberately small/quiet. {%- endcomment -%}
    {%- if s.address != blank -%}
      <details class="tdn-contact__legal">
        <summary>Business details</summary>
        <span>{{ s.address }}</span>
      </details>
    {%- endif -%}
  </section>
</div>

{% stylesheet %}
  .tdn-contact { max-width: 720px; margin: 0 auto; padding: 64px var(--tdn-side-pad); }
  .tdn-contact__lead { font-size: 15px; line-height: 1.6; color: var(--tdn-muted-2); margin: 0 0 6px; }
  .tdn-contact__sub { font-size: 14px; color: var(--tdn-faint); margin: 0 0 28px; }
  .tdn-contact__form { display: flex; flex-direction: column; gap: 14px; }
  .tdn-contact__ok { background: #eef2e6; border: 1px solid #cdd8bb; color: #47563a; padding: 12px 16px; border-radius: 12px; }
  .tdn-contact__err { color: #a8442f; }
  .tdn-contact__legal { margin-top: 30px; font-size: 11.5px; color: var(--tdn-faint); }
  .tdn-contact__legal summary { cursor: pointer; list-style: none; font-size: 11.5px; letter-spacing: .3px; color: var(--tdn-faint); user-select: none; display: inline-flex; align-items: center; gap: 5px; }
  .tdn-contact__legal summary::-webkit-details-marker { display: none; }
  .tdn-contact__legal summary::before { content: '›'; display: inline-block; transition: transform .18s ease; }
  .tdn-contact__legal[open] summary::before { transform: rotate(90deg); }
  .tdn-contact__legal span { display: block; margin-top: 8px; line-height: 1.5; max-width: 460px; }
  @media (max-width: 760px) { .tdn-contact { padding: 44px var(--tdn-side-pad); } }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Contact",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Contact" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in touch" },
    { "type": "text", "id": "email", "label": "Contact email", "default": "hello@thedognook.co.uk" },
    { "type": "text", "id": "subtext", "label": "Sub text", "default": "We usually reply within 24 hours." },
    { "type": "text", "id": "address", "label": "Business address", "default": "The Dog Nook (Aryan Sarna) · 10 Old Farm Close, Hounslow, TW4 7AB, United Kingdom" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Send message" },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "Thanks — we’ll reply within 24 hours." }
  ],
  "presets": [ { "name": "TDN Contact" } ]
}
{% endschema %}
