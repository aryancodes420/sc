{%- comment -%}
  The Dog Nook — Shop all ("Comfort-first accessories").
  Use as the main section of a page template (templates/page.shop.json).
  Lists products from the chosen collection, or every product if none is chosen.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign shop_col = s.collection
  if shop_col == blank
    assign shop_col = collections['all']
  endif
-%}
<div class="tdn tdn-fade">
  <section class="tdn-section tdn-wrap">
    {%- if s.eyebrow != blank -%}<div class="tdn-eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
    {%- if s.heading != blank -%}<h1 class="tdn-h1 tdn-shop__h1">{{ s.heading }}</h1>{%- endif -%}
    {%- if s.subheading != blank -%}<p class="tdn-muted tdn-shop__sub">{{ s.subheading }}</p>{%- endif -%}

    <div class="tdn-shop__bar">
      <div class="tdn-shop__chips">
        {%- for block in section.blocks -%}
          {%- if block.type == 'chip' -%}
            <a href="{{ block.settings.url | default: '#' }}" class="tdn-chip {% if block.settings.active %}tdn-chip--on{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- if s.sort_label != blank -%}<span class="tdn-shop__sort">{{ s.sort_label }}</span>{%- endif -%}
    </div>

    {%- paginate shop_col.products by 24 -%}
      <div class="tdn-grid-4">
        {%- for product in shop_col.products -%}
          {% render 'dog-nook-product-card', card_product: product, show_tag: true %}
        {%- else -%}
          <p class="tdn-muted">No products yet.</p>
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}<div class="tdn-pagination">{{ paginate | default_pagination }}</div>{%- endif -%}
    {%- endpaginate -%}
  </section>
</div>

{% stylesheet %}
  .tdn-shop__h1 { font-size: 32px; }
  .tdn-shop__sub { max-width: 520px; margin-bottom: 22px; }
  .tdn-shop__bar { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 26px; }
  .tdn-shop__chips { display: flex; flex-wrap: wrap; gap: 10px; }
  .tdn-shop__sort { margin-left: auto; font-size: 13px; color: var(--tdn-faint); }
  .tdn-pagination { margin-top: 32px; text-align: center; font-size: 14px; }
{% endstylesheet %}

{% schema %}
{
  "name": "TDN Shop all",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop all" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Comfort-first accessories" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Comfort-first accessories for dogs who need a little extra calm." },
    { "type": "collection", "id": "collection", "label": "Products from collection", "info": "Leave empty to show every product." },
    { "type": "text", "id": "sort_label", "label": "Sort label (visual)", "default": "Sort: Best selling ▾" }
  ],
  "blocks": [
    { "type": "chip", "name": "Filter chip", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "All" },
      { "type": "url", "id": "url", "label": "Link" },
      { "type": "checkbox", "id": "active", "label": "Active (highlighted)", "default": false }
    ] }
  ],
  "presets": [ { "name": "TDN Shop all", "blocks": [
    { "type": "chip", "settings": { "label": "All", "active": true } },
    { "type": "chip", "settings": { "label": "Calming" } },
    { "type": "chip", "settings": { "label": "Grooming" } },
    { "type": "chip", "settings": { "label": "Feeding" } },
    { "type": "chip", "settings": { "label": "Travel" } }
  ] } ]
}
{% endschema %}
